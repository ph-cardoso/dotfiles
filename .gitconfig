# Portable git config. Machine-specific identity + commit signing live in
# ~/.gitconfig.local (gitignored; see .gitconfig.local.example).

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true

[commit]
	verbose = true

[branch]
	sort = -committerdate

[tag]
	sort = -version:refname

[rerere]
	enabled = true
	autoupdate = true

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status

[include]
	path = ~/.gitconfig.local
